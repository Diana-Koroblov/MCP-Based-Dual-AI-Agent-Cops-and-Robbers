# Copy this file to .env and fill in real values. Never commit .env.

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Gmail credentials path — absolute path to my_google.json OUTSIDE the project directory
GMAIL_CREDENTIALS_PATH=/home/youruser/private_google/my_google.json

# MCP server auth tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
COP_MCP_TOKEN=replace_with_random_hex_token
THIEF_MCP_TOKEN=replace_with_another_random_hex_token
